# Voltio Services Environment Configuration
# Copy this file to .env and configure the values according to your setup

# RabbitMQ Configuration
RABBITMQ_URI=amqp://user:password@host:5672/

# InfluxDB Configuration
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=your-bucket

# Queue Names
ALERTS_QUEUE_NAME=alerts-queue
PZEM_QUEUE_NAME=PZEM_queue
DHT22_QUEUE_NAME=DHT22_queue
LIGHT_QUEUE_NAME=LightSensor_queue
PIR_QUEUE_NAME=PIR_queue

# WebSocket URIs
PZEM_WEBSOCKET_URI=wss://example.com/ws?topic=pzem&emitter=true
DHT22_WEBSOCKET_URI=wss://example.com/ws?topic=dht22&emitter=true
LIGHT_WEBSOCKET_URI=wss://example.com/ws?topic=light_sensor&emitter=true
PIR_WEBSOCKET_URI=wss://example.com/ws?topic=pir&emitter=true

# Notification Service
API_WEBHOOK_URL=http://localhost:8000/api/internal/notifications/service
API_WEBHOOK_TOKEN=your-webhook-token-here

# WebSocket Server Configuration
WEBSOCKET_PORT=8081
