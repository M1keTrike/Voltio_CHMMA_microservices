# Voltio Services Environment Configuration
# Copy this file to .env and configure the values according to your setup

# RabbitMQ Configuration
RABBITMQ_URI=amqp://user:password@localhost:5672/

# InfluxDB Configuration
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=example-token
INFLUX_ORG=example-org
INFLUX_BUCKET=example-bucket

# Queue Names
ALERTS_QUEUE_NAME=alerts-queue
PZEM_QUEUE_NAME=pzem-data-queue
DHT22_QUEUE_NAME=dht22-data-queue
LIGHT_QUEUE_NAME=light-sensor-data-queue
PIR_QUEUE_NAME=pir-data-queue

# WebSocket URIs
PZEM_WEBSOCKET_URI=wss://example.com/ws?topic=pzem&emitter=true
DHT22_WEBSOCKET_URI=wss://example.com/ws?topic=dht22&emitter=true
LIGHT_WEBSOCKET_URI=wss://example.com/ws?topic=light&emitter=true
PIR_WEBSOCKET_URI=wss://example.com/ws?topic=pir&emitter=true

# Notification Service
API_WEBHOOK_URL=http://localhost:8000/api/internal/notifications
API_WEBHOOK_TOKEN=example-webhook-token

# WebSocket Server Configuration
WEBSOCKET_PORT=8081
