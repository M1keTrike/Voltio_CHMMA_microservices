# ==============================================================================
# VOLTIO BACKEND - VARIABLES DE ENTORNO PARA PRODUCCIÓN EC2
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=mike
POSTGRES_PASSWORD=trike
POSTGRES_DB=voltio_db

# ------------------------------------------------------------------------------
# InfluxDB
# ------------------------------------------------------------------------------
INFLUXDB_URL=http://influxdb-host:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=sensores

# ------------------------------------------------------------------------------
# RabbitMQ (AMQP puerto 5672)
# ------------------------------------------------------------------------------
RABBITMQ_URI=amqp://user:password@rabbitmq-host:5672/

# ------------------------------------------------------------------------------
# WebSocket URIs (para docker-compose.consumers.yml)
# Configurar solo si WebSocket Server corre externamente
# ------------------------------------------------------------------------------
PIR_WEBSOCKET_URI=ws://websocket-host:8081/ws?topic=pir&emitter=true
DHT22_WEBSOCKET_URI=ws://websocket-host:8081/ws?topic=dht22&emitter=true
LIGHT_WEBSOCKET_URI=ws://websocket-host:8081/ws?topic=light&emitter=true
PZEM_WEBSOCKET_URI=ws://websocket-host:8081/ws?topic=pzem&emitter=true

# ------------------------------------------------------------------------------
# Notification Consumer - Webhook URL
# ------------------------------------------------------------------------------
WEBHOOK_URL=https://voltioapi.acstree.xyz/api/internal/notifications/service

