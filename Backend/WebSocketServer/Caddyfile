# Caddyfile - Configuración para WebSocket Server

voltiowebsocket.acstree.xyz { # Headers para WebSocket
header { # Permitir conexiones WebSocket
Connection "Upgrade"
Upgrade "websocket"
}

    # Reverse proxy con configuración optimizada para WebSockets
    reverse_proxy localhost:8081 {
        # Timeout extendido para conexiones WebSocket de larga duración
        transport http {
            read_timeout 0
            write_timeout 0
            dial_timeout 30s
        }

        # Headers necesarios para WebSocket
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

}
